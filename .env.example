# ===== AI Vision (photo analysis + storyboard) =====
# Get a free Gemini key at https://aistudio.google.com/app/apikey
VISION_API_KEY=
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_MODEL=gemini-2.5-flash

# ===== Video Generation =====
# FAL.ai key (image-to-video via Kling/SVD). https://fal.ai
# Leave empty to use a demo clip during development.
FAL_KEY=

# ===== Database (optional for MVP) =====
DATABASE_URL=postgresql://user:pass@localhost:5432/vidcraft

# ===== Auth (optional for MVP) =====
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Payment (Midtrans) =====
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
